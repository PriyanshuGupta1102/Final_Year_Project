{
  "name": "clinico",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install && npm install --workspace=frontend && npm install --workspace=backend",
    "build": "npm run build -w frontend",
    "start": "npm start -w backend",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:frontend": "npm start -w frontend",
    "start:backend": "npm start -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}